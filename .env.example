# =============================================================================
# TheTraderLog — Environment Variables
# =============================================================================
# Copy this file to `.env` and fill in the values:
#
#   cp .env.example .env
#
# Variables are validated at build/startup by `src/env.js` (@t3-oss/env-nextjs).
# REQUIRED variables must be set or the app will refuse to start. To bypass
# validation temporarily (e.g. for a Docker build step), set SKIP_ENV_VALIDATION=1.
#
# See SELF_HOSTING.md for step-by-step instructions on creating each account.
# NEVER commit your real `.env` — only this `.env.example` belongs in git.
# =============================================================================


# -----------------------------------------------------------------------------
# Database — PostgreSQL  (REQUIRED)
# -----------------------------------------------------------------------------
# Any PostgreSQL database works (driver: postgres-js). Neon is recommended for a
# free serverless option: https://neon.tech
DATABASE_URL="postgresql://user:password@host:5432/traderlog"

# Optional read replica. If unset, DATABASE_URL is used for reads too.
# DATABASE_READ_URL="postgresql://user:password@read-host:5432/traderlog"


# -----------------------------------------------------------------------------
# Authentication — Clerk  (REQUIRED)
# -----------------------------------------------------------------------------
# Create an application at https://dashboard.clerk.com
CLERK_SECRET_KEY="sk_test_xxxxxxxxxxxxxxxxxxxxxxxx"
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_xxxxxxxxxxxxxxxxxxxxxxxx"

# Clerk webhook signing secret — used to sync users into the local DB.
# Create a webhook in the Clerk dashboard pointing at:
#   https://<your-domain>/api/webhooks/clerk   (events: user.created, user.updated, user.deleted)
CLERK_WEBHOOK_SECRET="whsec_xxxxxxxxxxxxxxxxxxxxxxxx"

# Auth routing (these have sensible defaults — only override if you change routes)
# NEXT_PUBLIC_CLERK_SIGN_IN_URL="/sign-in"
# NEXT_PUBLIC_CLERK_SIGN_UP_URL="/sign-up"
# NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL="/dashboard"
# NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL="/dashboard"

# Clerk Billing plan IDs (OPTIONAL — only needed if you sell subscriptions).
# Self-hosters can leave these blank and instead unlock all features by setting
# `{ "features": { "beta_access": true } }` in their Clerk user's public metadata.
# See SELF_HOSTING.md → "Unlocking features".
# NEXT_PUBLIC_CLERK_PLAN_ID_STARTER=""
# NEXT_PUBLIC_CLERK_PLAN_ID_PRO=""
# NEXT_PUBLIC_CLERK_PLAN_ID_STARTER_ANNUAL=""
# NEXT_PUBLIC_CLERK_PLAN_ID_PRO_ANNUAL=""


# -----------------------------------------------------------------------------
# Market Data — Databento  (REQUIRED)
# -----------------------------------------------------------------------------
# Futures OHLC data (ES, NQ, etc.) powering MAE/MFE analysis.
# Get an API key at https://databento.com
DATABENTO_API_KEY="db-xxxxxxxxxxxxxxxxxxxxxxxx"


# -----------------------------------------------------------------------------
# Background Jobs — Trigger.dev  (REQUIRED)
# -----------------------------------------------------------------------------
# Runs the post-import market-data enrichment and AI report generation.
# Create a project at https://trigger.dev, then ALSO update the hardcoded
# project ref in `trigger.config.ts` to your own (e.g. proj_xxxxxxxx).
TRIGGER_SECRET_KEY="tr_dev_xxxxxxxxxxxxxxxxxxxxxxxx"


# -----------------------------------------------------------------------------
# Object Storage — S3-compatible  (REQUIRED)
# -----------------------------------------------------------------------------
# Stores trade screenshots and uploaded images. Cloudflare R2 is recommended
# (S3-compatible, generous free tier): https://developers.cloudflare.com/r2/
# Works with AWS S3, MinIO, Backblaze B2, etc.
S3_ENDPOINT="https://<account-id>.r2.cloudflarestorage.com"
S3_REGION="auto"
S3_ACCESS_KEY_ID="xxxxxxxxxxxxxxxxxxxx"
S3_SECRET_ACCESS_KEY="xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
S3_BUCKET="traderlog-assets"

# Public base URL for serving uploaded objects (OPTIONAL — required only if you
# embed images in shared/exported views; e.g. your R2 public bucket URL).
# S3_PUBLIC_URL="https://assets.example.com"


# -----------------------------------------------------------------------------
# AI — OpenRouter  (REQUIRED)
# -----------------------------------------------------------------------------
# Powers AI chat and AI-generated reports.
# Get a key at https://openrouter.ai/keys
OPENROUTER_API_KEY="sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxx"


# -----------------------------------------------------------------------------
# Optional integrations
# -----------------------------------------------------------------------------
# Daytona — sandboxed Python execution for the AI `run_python` tool.
# Without it, that single tool is unavailable; everything else works.
# https://www.daytona.io
# DAYTONA_API_KEY=""

# Resend — transactional email (AI report delivery).
# Without it, report emails are skipped. https://resend.com
# NOTE: the "from" address is set in src/lib/ai/report-email.ts — change it to a
# domain you've verified in Resend.
# RESEND_API_KEY=""

# Sentry — error monitoring. If unset, errors are silently dropped (no crash).
# https://sentry.io
# SENTRY_DSN=""
# NEXT_PUBLIC_SENTRY_DSN=""
# Build-time only (source-map upload during `bun run build`):
# SENTRY_ORG=""
# SENTRY_PROJECT=""
# SENTRY_AUTH_TOKEN=""


# -----------------------------------------------------------------------------
# App
# -----------------------------------------------------------------------------
# Public base URL of your deployment. Used for absolute links, SEO, and emails.
# Defaults to http://localhost:3000 in dev if unset.
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# NODE_ENV is managed by the framework (development | test | production).
